{
  "name": "Agent Template",
  "description": "A minimal federation node template. Replace this with your node's purpose.",
  "url": "https://github.com/kimeisele/agent-template",
  "version": "1.0.0",
  "capabilities": {
    "streaming": false,
    "pushNotifications": false
  },
  "skills": [
    {
      "id": "authority-publishing",
      "name": "Authority Publishing",
      "description": "Authority Publishing capability."
    }
  ],
  "provider": {
    "organization": "kimeisele"
  },
  "federation": {
    "node_topic": "agent-federation-node",
    "node_role": "agent_template_relay",
    "descriptor_path": ".well-known/agent-federation.json",
    "authority_feed_branch": "authority-feed",
    "interfaces": {
      "produces": [
        "authority_document",
        "canonical_surface"
      ],
      "consumes": [],
      "protocols": [
        "authority_feed_v1"
      ]
    },
    "peer_discovery": true
  }
}
