      "authority_feed_v1"
    ]
  },
  "protocols": [
    {
      "name": "agent-federation",
      "version": 1,
      "descriptor": ".well-known/agent-federation.json"
    },
    {
      "name": "a2a-agent-card",
      "version": "1.0.0",
      "descriptor": ".well-known/agent.json"
    }
  ]
